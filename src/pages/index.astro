---
import '@fontsource-variable/onest';
import ProjectHero from '../components/ProjectHero.astro';
import ScrambleLink from '../components/ScrambleLink.astro';

const navigation = [
	{ label: 'Работы', href: '#works' },
	{ label: 'Обо мне', href: '#about' },
	{ label: 'Контакты', href: '#contacts' },
];

const projects = [
	{
		title: 'ADDINOL',
		category: 'e-commerce',
		imageAlt: 'Проект ADDINOL',
	},
];
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Портфолио Олега Кротова — digital designer."
		/>
		<title>Олег Кротов — Digital Designer</title>
	</head>
	<body>
		<div class="page-grid">
			<aside class="sidebar">
				<a class="identity" href="/" aria-label="Олег Кротов — на главную">
					<strong>Олег Кротов</strong>
					<span>Digital Designer</span>
				</a>

				<nav aria-label="Основная навигация">
					{navigation.map((item, index) => (
						<>
							<ScrambleLink href={item.href} label={item.label} />
							{index < navigation.length - 1 && <span class="nav-separator" aria-hidden="true">,</span>}
						</>
					))}
				</nav>
			</aside>

			<main id="works">
				{projects.map((project) => <ProjectHero {...project} />)}
			</main>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--page-padding: 40px;
		--grid-gap: 20px;
		--grid-columns: 12;
		--color-text: #19191c;
		--color-muted: rgb(25 25 28 / 60%);
		--color-background: #fff;
		--color-project: #d6e0e5;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		min-width: 1140px;
		background: var(--color-background);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		color: var(--color-text);
		background: var(--color-background);
		font-family: 'Onest Variable', Onest, sans-serif;
		font-synthesis: none;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.page-grid {
		display: grid;
		grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
		column-gap: var(--grid-gap);
		padding-inline: var(--page-padding);
	}

	.sidebar {
		position: sticky;
		top: 0;
		display: flex;
		grid-column: 1 / span 3;
		flex-direction: column;
		justify-content: space-between;
		height: 100svh;
		padding-block: var(--page-padding);
	}

	.identity {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.identity strong {
		font-size: 20px;
		font-weight: 500;
		line-height: 24px;
	}

	.identity span {
		color: var(--color-muted);
		font-size: 16px;
		font-weight: 400;
		line-height: 24px;
	}

	nav {
		display: flex;
		align-items: center;
		font-size: 20px;
		font-weight: 500;
		line-height: 24px;
		white-space: nowrap;
	}

	.nav-separator {
		padding-block: 12px;
		padding-right: 6px;
	}

	main {
		grid-column: 4 / span 9;
		min-width: 0;
	}
</style>
