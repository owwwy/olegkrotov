---
import '@fontsource-variable/onest';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import ProjectCaseModal from '../components/ProjectCaseModal.astro';
import ScrambleLink from '../components/ScrambleLink.astro';
import { projects } from '../data/projects';

const navigation = [
	{ label: 'Работы', href: '#works' },
	{ label: 'Обо мне', href: '#about' },
	{ label: 'Контакты', href: '#contacts' },
];

---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const interpolate = (from, to, progress) => from + (to - from) * progress;
				const roundToEven = (value) => Math.round(value / 2) * 2;
				const scale = (width, compact, desktop, wide) => {
					if (width <= 1200) return compact;
					if (width < 1780) return interpolate(compact, desktop, (width - 1200) / 580);
					if (width <= 1920) return desktop;
					if (width < 2048) return interpolate(desktop, wide, (width - 1920) / 128);
					return wide;
				};

				const updateTypeScale = () => {
					const width = window.innerWidth;
					const ui = Math.round(scale(width, 16, 20, 28));
					const title = Math.round(scale(width, 80, 120, 160));
					const root = document.documentElement;
					root.style.setProperty('--ui-font-size', `${ui}px`);
					root.style.setProperty('--ui-line-height', `${roundToEven(ui * 1.2)}px`);
					root.style.setProperty('--role-font-size', `${Math.round(ui * 0.8)}px`);
					root.style.setProperty('--project-title-size', `${title}px`);
					root.style.setProperty('--project-title-line-height', `${roundToEven(title)}px`);
				};

				updateTypeScale();
				window.addEventListener('resize', updateTypeScale, { passive: true });
			})();
		</script>
		<meta
			name="description"
			content="Портфолио Олега Кротова — digital designer."
		/>
		<title>Олег Кротов — Digital Designer</title>
	</head>
	<body>
		<div class="page-grid">
			<aside class="sidebar">
				<a class="identity" href="/" aria-label="Олег Кротов — на главную" data-scramble-link>
					<strong data-scramble-text data-original="Олег Кротов">
						{[...'Олег Кротов'].map((character) => (
							<span class="scramble-link__char">{character === ' ' ? '\u00a0' : character}</span>
						))}
					</strong>
					<span data-scramble-text data-original="Digital Designer">
						{[...'Digital Designer'].map((character) => (
							<span class="scramble-link__char">{character === ' ' ? '\u00a0' : character}</span>
						))}
					</span>
				</a>

				<nav aria-label="Основная навигация">
					{navigation.map((item, index) => (
						<>
							<ScrambleLink href={item.href} label={item.label} />
							{index < navigation.length - 1 && <span class="nav-separator" aria-hidden="true">,</span>}
						</>
					))}
				</nav>
			</aside>

			<main id="works">
				<ProjectShowcase projects={projects} />
			</main>
		</div>
		<ProjectCaseModal projects={projects} />
	</body>
</html>

<style is:global>
	:root {
		--page-padding: 40px;
		--grid-gap: 20px;
		--grid-columns: 12;
		--color-text: #19191c;
		--color-muted: rgb(25 25 28 / 60%);
		--color-background: #fff;
		--color-project: #d6e0e5;
		--ui-font-size: 20px;
		--ui-line-height: 24px;
		--role-font-size: 16px;
		--project-title-size: 120px;
		--project-title-line-height: 120px;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
		scrollbar-width: none;
	}

	*::-webkit-scrollbar {
		display: none;
		width: 0;
		height: 0;
	}

	.c-scrollbar {
		display: none !important;
	}

	html {
		min-width: 1140px;
		height: 100%;
		background: var(--color-background);
		overflow: hidden;
	}

	body {
		height: 100%;
		margin: 0;
		color: var(--color-text);
		background: var(--color-background);
		font-family: 'Onest Variable', Onest, sans-serif;
		font-synthesis: none;
		overflow: hidden;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.page-grid {
		display: grid;
		grid-template-columns: repeat(var(--grid-columns), minmax(0, 1fr));
		column-gap: var(--grid-gap);
		padding-inline: var(--page-padding);
	}

	.sidebar {
		position: sticky;
		top: 0;
		display: flex;
		grid-column: 1 / span 3;
		flex-direction: column;
		justify-content: space-between;
		height: 100svh;
		padding-block: var(--page-padding);
	}

	.identity {
		display: flex;
		align-items: flex-start;
		flex-direction: column;
	}

	.identity strong {
		font-size: var(--ui-font-size);
		font-weight: 400;
		line-height: var(--ui-line-height);
	}

	.identity > span {
		color: var(--color-muted);
		font-size: var(--role-font-size);
		font-weight: 300;
		line-height: var(--ui-line-height);
	}

	.identity [data-scramble-text],
	.identity .scramble-link__char {
		display: inline-block;
	}

	nav {
		display: flex;
		align-items: center;
		font-size: var(--ui-font-size);
		font-weight: 400;
		line-height: var(--ui-line-height);
		white-space: nowrap;
	}

	.nav-separator {
		padding-block: 12px;
		padding-right: 6px;
	}

	main {
		grid-column: 4 / span 9;
		min-width: 0;
	}
</style>
