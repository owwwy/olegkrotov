---
interface Props {
	title: string;
	category: string;
	image?: string;
	imageAlt?: string;
}

const { title, category, image, imageAlt = '' } = Astro.props;
---

<article class="project">
	<div class="project__media">
		{image ? (
			<img src={image} alt={imageAlt} loading="eager" />
		) : (
			<div class="project__placeholder" aria-hidden="true">
				<span>AK</span>
			</div>
		)}
	</div>

	<header class="project__heading">
		<h2>{title}</h2>
		<p>{category}</p>
	</header>
</article>

<style>
	.project {
		display: grid;
		grid-template-columns: repeat(9, minmax(0, 1fr));
		column-gap: var(--grid-gap);
		align-items: center;
		min-height: 100svh;
		padding-block: var(--page-padding);
	}

	.project__media {
		grid-column: 3 / span 7;
		grid-row: 1;
		align-self: stretch;
		min-height: calc(100svh - (2 * var(--page-padding)));
		overflow: hidden;
		background: var(--color-project);
	}

	.project__media img,
	.project__placeholder {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project__placeholder {
		display: grid;
		place-items: center;
		background:
			radial-gradient(circle at 72% 28%, rgb(255 255 255 / 55%), transparent 26%),
			linear-gradient(145deg, #d6e0e5 0%, #b8c9d1 55%, #8ba3af 100%);
	}

	.project__placeholder span {
		color: rgb(25 25 28 / 8%);
		font-size: 28vw;
		font-weight: 700;
		letter-spacing: -0.1em;
		line-height: 1;
		transform: translateX(-0.04em);
	}

	.project__heading {
		position: relative;
		z-index: 1;
		grid-column: 1 / span 5;
		grid-row: 1;
	}

	h2,
	p {
		margin: 0;
	}

	h2 {
		font-size: 120px;
		font-weight: 700;
		letter-spacing: -0.06em;
		line-height: 120px;
	}

	p {
		color: var(--color-muted);
		font-size: 20px;
		font-weight: 500;
		line-height: 24px;
	}
</style>
