---
interface Props {
	href: string;
	label: string;
}

const { href, label } = Astro.props;
---

<a class="scramble-link" href={href} aria-label={label} data-scramble-link>
	<span class="scramble-link__text" aria-hidden="true" data-scramble-text data-original={label}>
		{[...label].map((character) => (
			<span class="scramble-link__char">{character === ' ' ? '\u00a0' : character}</span>
		))}
	</span>
</a>

<script>
	const DURATION = 260;
	const MIN_TICK = 38;
	const MAX_TICK = 76;
	const LOCKED_CHARACTERS = new Set([' ', '+', '(', ')', '-', '–', '—']);
	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	const shuffle = (values: string[]) => {
		const result = [...values];

		for (let index = result.length - 1; index > 0; index -= 1) {
			const target = Math.floor(Math.random() * (index + 1));
			[result[index], result[target]] = [result[target], result[index]];
		}

		return result;
	};

	const render = (spans: HTMLElement[], characters: string[]) => {
		spans.forEach((span, index) => {
			span.textContent = characters[index] === ' ' ? '\u00a0' : characters[index];
		});
	};

	const animate = (link: HTMLElement) => {
		const text = link.querySelector<HTMLElement>('[data-scramble-text]');
		if (!text || text.dataset.animating === 'true' || reduceMotion.matches) return;

		const original = [...(text.dataset.original ?? '')];
		const spans = [...text.querySelectorAll<HTMLElement>('.scramble-link__char')];
		const mutableIndexes = original.flatMap((character, index) =>
			LOCKED_CHARACTERS.has(character) ? [] : [index],
		);
		const mutableCharacters = mutableIndexes.map((index) => original[index]);

		text.style.width = `${text.getBoundingClientRect().width}px`;
		text.dataset.animating = 'true';

		const startedAt = performance.now();
		let nextTick = startedAt;

		const frame = (now: number) => {
			const progress = Math.min(1, (now - startedAt) / DURATION);
			const eased = 1 - Math.pow(1 - progress, 3);

			if (now >= nextTick) {
				nextTick = now + MIN_TICK + (MAX_TICK - MIN_TICK) * eased;
				const scrambled = [...original];
				const shuffled = shuffle(mutableCharacters);
				mutableIndexes.forEach((characterIndex, index) => {
					scrambled[characterIndex] = shuffled[index];
				});
				render(spans, scrambled);
			}

			if (progress < 1) {
				requestAnimationFrame(frame);
				return;
			}

			render(spans, original);
			text.dataset.animating = 'false';
		};

		requestAnimationFrame(frame);
	};

	document.querySelectorAll<HTMLElement>('[data-scramble-link]').forEach((link) => {
		if (link.dataset.scrambleBound === 'true') return;
		link.dataset.scrambleBound = 'true';
		link.addEventListener('pointerenter', () => animate(link));
		link.addEventListener('focus', () => animate(link));
	});
</script>

<style>
	.scramble-link {
		display: inline-flex;
		padding-block: 12px;
	}

	.scramble-link__text {
		position: relative;
		display: inline-block;
	}

	.scramble-link__text::after {
		position: absolute;
		right: 0;
		bottom: -2px;
		left: 0;
		height: 1px;
		background: currentColor;
		content: '';
		transform: scaleX(0);
		transform-origin: right;
		transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.scramble-link:hover .scramble-link__text::after,
	.scramble-link:focus-visible .scramble-link__text::after {
		transform: scaleX(1);
		transform-origin: left;
	}

	.scramble-link__char {
		display: inline-block;
	}

	.scramble-link:focus-visible {
		outline: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.scramble-link__text::after {
			transition-duration: 0.01ms;
		}
	}
</style>
