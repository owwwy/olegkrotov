---
import type { Project } from '../data/projects';

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;
const firstProject = projects[0];
---

<section class="showcase" data-project-showcase>
	<div class="showcase__media" data-project-media>
		{projects.map((project, index) => (
			<div
				class="showcase__panel"
				data-project-panel
				data-title={project.title}
				data-category={project.category}
				aria-hidden={index === 0 ? 'false' : 'true'}
				style={`transform: translate3d(0, ${index * 100}%, 0)`}
			>
				<img src={project.image} alt={project.imageAlt} loading={index === 0 ? 'eager' : 'lazy'} />
			</div>
		))}
	</div>

	<header class="showcase__heading">
		<h2 aria-live="polite" data-project-title aria-label={firstProject.title}>
			{[...firstProject.title].map((character) => <span>{character}</span>)}
		</h2>
		<p data-project-category>{firstProject.category}</p>
	</header>
</section>

<script>
	const SCRAMBLE_DURATION = 320;
	const SCRAMBLE_TICK = 42;
	const TRANSITION_DURATION = 720;
	const WHEEL_THRESHOLD = 110;
	const TOUCH_THRESHOLD = 54;
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	const randomCharacter = (pool: string[]) => pool[Math.floor(Math.random() * pool.length)] ?? '';

	const renderTitle = (element: HTMLElement, value: string) => {
		element.replaceChildren(
			...[...value].map((character) => {
				const span = document.createElement('span');
				span.textContent = character;
				return span;
			}),
		);
	};

	const scrambleTitle = (element: HTMLElement, from: string, to: string) => {
		element.setAttribute('aria-label', to);

		if (reducedMotion.matches) {
			renderTitle(element, to);
			return;
		}

		const target = [...to];
		const pool = [...new Set([...from, ...to].filter((character) => character !== ' '))];
		const length = Math.max([...from].length, target.length);
		const startedAt = performance.now();
		let lastTick = 0;

		const frame = (now: number) => {
			const progress = Math.min(1, (now - startedAt) / SCRAMBLE_DURATION);

			if (now - lastTick >= SCRAMBLE_TICK || progress === 1) {
				lastTick = now;
				const lockedCount = Math.floor(progress * length);
				const next = Array.from({ length }, (_, index) =>
					index < lockedCount ? (target[index] ?? '') : randomCharacter(pool),
				).join('');
				renderTitle(element, progress === 1 ? to : next);
			}

			if (progress < 1) requestAnimationFrame(frame);
		};

		requestAnimationFrame(frame);
	};

	document.querySelectorAll<HTMLElement>('[data-project-showcase]').forEach((showcase) => {
		const media = showcase.querySelector<HTMLElement>('[data-project-media]');
		const panels = [...showcase.querySelectorAll<HTMLElement>('[data-project-panel]')];
		const title = showcase.querySelector<HTMLElement>('[data-project-title]');
		const category = showcase.querySelector<HTMLElement>('[data-project-category]');
		if (!media || !title || !category || panels.length === 0) return;

		let activeIndex = 0;
		let wheelAmount = 0;
		let wheelDirection = 0;
		let lastWheelAt = 0;
		let isTransitioning = false;
		let touchStartY = 0;
		let touchCurrentY = 0;
		let resistanceFrame = 0;
		let releaseTimer = 0;

		const setResistance = (amount: number, direction: number) => {
			const strength = Math.min(1, Math.max(0, amount));
			media.style.setProperty('--lens-scale-x', `${1 + strength * 0.018}`);
			media.style.setProperty('--lens-scale-y', `${1 - strength * 0.028}`);
			media.style.setProperty('--lens-shift-y', `${direction * strength * -7}px`);
			media.style.setProperty('--lens-radius', `${strength * 26}px`);
			media.style.setProperty('--lens-light', `${strength * 0.34}`);
		};

		const releaseResistance = () => {
			window.clearTimeout(releaseTimer);
			cancelAnimationFrame(resistanceFrame);
			const decay = () => {
				wheelAmount *= 0.78;
				setResistance(Math.abs(wheelAmount) / WHEEL_THRESHOLD, wheelDirection);
				if (Math.abs(wheelAmount) > 0.5) {
					resistanceFrame = requestAnimationFrame(decay);
					return;
				}
				wheelAmount = 0;
				wheelDirection = 0;
				setResistance(0, 0);
			};
			resistanceFrame = requestAnimationFrame(decay);
		};

		const selectProject = (nextIndex: number) => {
			if (isTransitioning || nextIndex === activeIndex || nextIndex < 0 || nextIndex >= panels.length) {
				releaseResistance();
				return;
			}

			isTransitioning = true;
			const previousTitle = panels[activeIndex].dataset.title ?? '';
			const nextTitle = panels[nextIndex].dataset.title ?? '';
			activeIndex = nextIndex;

			panels.forEach((panel, index) => {
				panel.style.transform = `translate3d(0, ${(index - activeIndex) * 100}%, 0)`;
				panel.setAttribute('aria-hidden', index === activeIndex ? 'false' : 'true');
			});

			scrambleTitle(title, previousTitle, nextTitle);
			category.textContent = panels[activeIndex].dataset.category ?? '';
			wheelAmount = 0;
			setResistance(0, 0);

			window.setTimeout(() => {
				isTransitioning = false;
			}, reducedMotion.matches ? 0 : TRANSITION_DURATION);
		};

		const move = (direction: number) => selectProject(activeIndex + direction);

		const onWheel = (event: WheelEvent) => {
			event.preventDefault();
			if (isTransitioning || Math.abs(event.deltaY) < Math.abs(event.deltaX)) return;

			const normalizedDelta = event.deltaMode === 1 ? event.deltaY * 16 : event.deltaY;
			const direction = Math.sign(normalizedDelta);
			if (direction === 0) return;

			if (direction !== wheelDirection || performance.now() - lastWheelAt > 180) wheelAmount = 0;
			wheelDirection = direction;
			lastWheelAt = performance.now();
			wheelAmount += Math.min(34, Math.abs(normalizedDelta));
			setResistance(wheelAmount / WHEEL_THRESHOLD, direction);

			if (wheelAmount >= WHEEL_THRESHOLD) {
				move(direction);
				return;
			}

			window.clearTimeout(releaseTimer);
			releaseTimer = window.setTimeout(releaseResistance, 110);
		};

		const onKeyDown = (event: KeyboardEvent) => {
			if (['ArrowDown', 'PageDown', ' '].includes(event.key)) {
				event.preventDefault();
				move(1);
			}
			if (['ArrowUp', 'PageUp'].includes(event.key)) {
				event.preventDefault();
				move(-1);
			}
		};

		const onTouchStart = (event: TouchEvent) => {
			touchStartY = event.touches[0]?.clientY ?? 0;
			touchCurrentY = touchStartY;
		};

		const onTouchMove = (event: TouchEvent) => {
			touchCurrentY = event.touches[0]?.clientY ?? touchCurrentY;
			const distance = touchStartY - touchCurrentY;
			setResistance(Math.abs(distance) / TOUCH_THRESHOLD, Math.sign(distance));
			if (Math.abs(distance) > 8) event.preventDefault();
		};

		const onTouchEnd = () => {
			const distance = touchStartY - touchCurrentY;
			if (Math.abs(distance) >= TOUCH_THRESHOLD) move(Math.sign(distance));
			else releaseResistance();
		};

		window.addEventListener('wheel', onWheel, { passive: false });
		window.addEventListener('keydown', onKeyDown);
		window.addEventListener('touchstart', onTouchStart, { passive: true });
		window.addEventListener('touchmove', onTouchMove, { passive: false });
		window.addEventListener('touchend', onTouchEnd, { passive: true });
	});
</script>

<style>
	.showcase {
		display: grid;
		grid-template-columns: repeat(9, minmax(0, 1fr));
		column-gap: var(--grid-gap);
		align-items: center;
		height: 100svh;
		padding-block: var(--page-padding);
	}

	.showcase__media {
		--lens-scale-x: 1;
		--lens-scale-y: 1;
		--lens-shift-y: 0px;
		--lens-radius: 0px;
		--lens-light: 0;
		position: relative;
		grid-column: 3 / span 7;
		grid-row: 1;
		align-self: stretch;
		overflow: hidden;
		background: var(--color-project);
		border-radius: var(--lens-radius);
		isolation: isolate;
		transform: translate3d(0, var(--lens-shift-y), 0) scaleX(var(--lens-scale-x)) scaleY(var(--lens-scale-y));
		transition:
			transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
			border-radius 180ms cubic-bezier(0.22, 1, 0.36, 1);
		will-change: transform;
	}

	.showcase__media::after {
		position: absolute;
		z-index: 2;
		inset: 0;
		background:
			linear-gradient(180deg, rgb(255 255 255 / 42%), transparent 18%, transparent 82%, rgb(0 0 0 / 10%)),
			radial-gradient(ellipse at center, transparent 48%, rgb(255 255 255 / 34%) 100%);
		content: '';
		opacity: var(--lens-light);
		pointer-events: none;
		transition: opacity 140ms ease-out;
	}

	.showcase__panel {
		position: absolute;
		inset: 0;
		transition: transform 720ms cubic-bezier(0.76, 0, 0.24, 1);
		will-change: transform;
	}

	.showcase__panel img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.showcase__heading {
		position: relative;
		z-index: 3;
		grid-column: 1 / span 5;
		grid-row: 1;
		pointer-events: none;
	}

	h2,
	p {
		margin: 0;
	}

	h2 {
		font-size: 120px;
		font-weight: 700;
		line-height: 120px;
		white-space: nowrap;
	}

	h2 span {
		display: inline-block;
	}

	p {
		color: var(--color-muted);
		font-size: 20px;
		font-weight: 500;
		line-height: 24px;
	}

	@media (prefers-reduced-motion: reduce) {
		.showcase__media,
		.showcase__panel,
		.showcase__media::after {
			transition-duration: 0.01ms;
			will-change: auto;
		}
	}
</style>
